# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Server-only secret key (sb_secret_...). Used only by API routes / server components.
# Do NOT use a NEXT_PUBLIC_ name for this — that would ship the key to the browser.
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Cron job auth (generate a random secret, set in Vercel env vars)
CRON_SECRET=

# Maestro API (Liquidity Services search backend)
MAESTRO_API_URL=https://maestro.lqdt1.com
MAESTRO_API_KEY=af93060f-337e-428c-87b8-c74b5837d6cd
AUCTIONS_DEFAULT_CLOSE_RATE=0.35
HISTORICAL_GMV_DAILY_PATH=scripts/historical-gmv-daily-2025-06-2026-06.csv
HISTORICAL_GMV_DAILY_MARKET_PATH=scripts/historical-gmv-daily-market-2025-06-2026-06.csv
MARKETPLACE_METRICS_PAGE_SIZE=1000
MARKETPLACE_METRICS_MAX_PAGES=25

# Database cost controls
# Daily reconciliation accepts either hour so a fixed-UTC scheduler remains
# aligned across daylight-saving changes. Four-hour scheduling hits only one.
DAILY_INGEST_HOURS_ET=11,12
SOLD_CAPTURE_LOOKBACK_DAYS=3
FORECAST_CACHE_MS=900000
DASHBOARD_CACHE_MS=900000
EXPORT_MAX_RANGE_DAYS=366

# Resend (optional — omit to skip email notifications)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=LQDT Tracker <notifications@yourdomain.com>
# Comma-separated allow-list for manual snapshot recipients + report recipients
NOTIFICATION_EMAIL=you@example.com
# ET hours the automated report email fires (DST-safe: noon = 11/12, 5pm = 16/17).
REPORT_HOURS_ET=11,12,16,17

# SAM.gov Opportunities API (free key at https://sam.gov/profile/details → API Key)
SAM_API_KEY=your-sam-api-key

# --- Authentication (Microsoft Entra ID SSO) ---
# Sign-in is restricted to this email domain. See AUTH_SETUP.md for the full
# Azure App Registration walkthrough.
AUTH_ALLOWED_DOMAIN=clearlinecap.com
# Random 32+ byte secret used to sign the session cookie: `openssl rand -base64 32`
AUTH_SECRET=
# Public URL of the app. Set in production so it EXACTLY matches the redirect URI
# registered in Entra. Leave blank in local dev (derived from the request host).
# AUTH_BASE_URL=https://your-app.azurecontainerapps.io
# Entra app registration (Azure Portal → App registrations)
ENTRA_TENANT_ID=your-tenant-guid
ENTRA_CLIENT_ID=your-app-client-id
ENTRA_CLIENT_SECRET=your-app-client-secret
